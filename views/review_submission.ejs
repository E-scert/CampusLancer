<%- include('partials/header', { user: user, title: 'Review Submission' }) %>

<div class="page-hero">
  <div class="page-hero-inner" style="display:flex;align-items:center;justify-content:space-between;flex-wrap:wrap;gap:1rem">
    <div>
      <h1 style="font-size:1.6rem;margin-bottom:0.2rem">Review Submission</h1>
      <p style="color:var(--gray-600)">Review the student's work, add feedback, and endorse the submission.</p>
    </div>
    <a href="/business/dashboard" class="btn btn-outline btn-sm">Back to Dashboard</a>
  </div>
</div>

<div class="page">
  <div class="card" style="margin-bottom:2rem">
    <div style="display:flex;align-items:center;justify-content:space-between;flex-wrap:wrap;gap:1rem">
      <div>
        <div style="font-size:0.95rem;color:var(--gray-500);margin-bottom:0.5rem">Task</div>
        <div style="font-weight:700;font-size:1.2rem;color:var(--blue-900)"><%= submission.task_title %></div>
        <div style="margin-top:0.75rem;font-size:0.95rem;color:var(--gray-700)">Student: <strong><%= submission.first_name %> <%= submission.last_name %></strong></div>
        <div style="font-size:0.85rem;color:var(--gray-500)">Institution: <%= submission.institution %></div>
      </div>
      <div style="text-align:right">
        <div style="font-size:0.85rem;color:var(--gray-500)">Submitted</div>
        <div style="font-weight:700;"><%= submission.submitted_at %></div>
      </div>
    </div>
    <div style="margin-top:1.25rem;display:flex;gap:1rem;flex-wrap:wrap">
      <a href="<%= submission.submission_url %>" target="_blank" class="btn btn-primary">Open Student Work</a>
      <span style="display:inline-flex;align-items:center;gap:0.4rem;font-weight:600;color:var(--gray-700);">Notes:<span style="font-weight:400;color:var(--gray-500)"><%= submission.notes || 'No notes provided' %></span></span>
    </div>
  </div>

  <div class="card">
    <form method="POST" action="/business/feedback">
      <input type="hidden" name="submission_id" value="<%= submission.submission_id %>">
      <div style="display:grid;gap:1.25rem">
        <div>
          <label class="form-label" for="feedback">Feedback</label>
          <textarea id="feedback" name="feedback" rows="6" class="form-input" style="width:100%;min-height:140px"><%= submission.feedback || '' %></textarea>
        </div>

        <div style="display:grid;grid-template-columns:1fr 1fr;gap:1rem;align-items:flex-end">
          <div>
            <label class="form-label" for="endorsement_status">Endorsement status</label>
            <select id="endorsement_status" name="endorsement_status" class="form-input" style="width:100%">
              <option value="pending" <%= submission.endorsement_status === 'pending' ? 'selected' : '' %>>Pending review</option>
              <option value="approved" <%= submission.endorsement_status === 'approved' ? 'selected' : '' %>>Approved</option>
              <option value="needs_revision" <%= submission.endorsement_status === 'needs_revision' ? 'selected' : '' %>>Needs revision</option>
              <option value="rejected" <%= submission.endorsement_status === 'rejected' ? 'selected' : '' %>>Rejected</option>
            </select>
          </div>

          <div>
            <label class="form-label" for="endorsement_rating">Endorsement rating</label>
            <select id="endorsement_rating" name="endorsement_rating" class="form-input" style="width:100%">
              <option value="" <%= submission.endorsement_rating == null ? 'selected' : '' %>>No rating</option>
              <% for (let i=1; i<=5; i++) { %>
                <option value="<%= i %>" <%= submission.endorsement_rating == i ? 'selected' : '' %>><%= i %> ★</option>
              <% } %>
            </select>
          </div>
        </div>

        <div style="display:flex;justify-content:flex-end;gap:0.75rem;flex-wrap:wrap">
          <a href="/business/dashboard" class="btn btn-outline">Cancel</a>
          <button type="submit" class="btn btn-primary">Save review</button>
        </div>
      </div>
    </form>
  </div>
</div>

<%- include('partials/footer') %>
