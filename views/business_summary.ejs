<%- include('partials/header', { user: user, title: 'Business Summary Report' }) %>

<div class="page-hero">
  <div class="page-hero-inner" style="display:flex;align-items:center;justify-content:space-between;flex-wrap:wrap;gap:1rem">
    <div>
      <h1 style="font-size:1.6rem;margin-bottom:0.2rem">Business Summary Report</h1>
      <p style="color:var(--gray-600)">Your company's activity, tasks, applicants, and submissions.</p>
    </div>
    <div style="display:flex;gap:0.75rem">
      <a href="/business/dashboard" class="btn btn-outline btn-sm">← Back to Dashboard</a>
      <a href="/business/reports/export-pdf?startDate=<%= startDate %>&endDate=<%= endDate %>" class="btn btn-primary btn-sm">
        ⬇ Download PDF
      </a>
    </div>
  </div>
</div>

<div class="page">
  <!-- Filter Form -->
  <div class="card fade-up" style="margin-bottom:2rem">
    <form method="get" action="/business/reports/summary" style="display:flex;gap:1rem;flex-wrap:wrap;align-items:flex-end">
      <div>
        <label class="form-label" for="startDate">Start Date</label>
        <input type="date" id="startDate" name="startDate" value="<%= startDate || '' %>" class="form-input" style="width:auto">
      </div>
      <div>
        <label class="form-label" for="endDate">End Date</label>
        <input type="date" id="endDate" name="endDate" value="<%= endDate || '' %>" class="form-input" style="width:auto">
      </div>
      <button type="submit" class="btn btn-primary">Apply Filter</button>
    </form>
    <p style="font-size:0.875rem;color:var(--gray-600);margin-top:0.5rem">
      <% if (startDate && endDate) { %>
        Showing data from <%= startDate %> to <%= endDate %>
      <% } else { %>
        Showing all time data
      <% } %>
    </p>
  </div>

  <!-- Company Info -->
  <div class="card fade-up-2" style="margin-bottom:2rem">
    <div class="grid-2">
      <div>
        <div class="stat-label">Company</div>
        <div class="stat-value"><%= profile.company_name %></div>
      </div>
      <div>
        <div class="stat-label">Industry</div>
        <div class="stat-value"><%= profile.industry %></div>
      </div>
      <div>
        <div class="stat-label">Email</div>
        <div class="stat-value"><%= profile.company_email %></div>
      </div>
      <div>
        <div class="stat-label">Total Tasks Posted</div>
        <div class="stat-value"><%= tasksCount.total_tasks %></div>
      </div>
      <div>
        <div class="stat-label">Total Applicants</div>
        <div class="stat-value"><%= applicantsCount.total_applicants %></div>
      </div>
      <div>
        <div class="stat-label">Accepted Applicants</div>
        <div class="stat-value"><%= applicantsCount.accepted_applicants %></div>
      </div>
      <div>
        <div class="stat-label">Rejected Applicants</div>
        <div class="stat-value"><%= applicantsCount.rejected_applicants %></div>
      </div>
      <div>
        <div class="stat-label">Total Submissions</div>
        <div class="stat-value"><%= submissionsCount.total_submissions %></div>
      </div>
    </div>
  </div>

  <!-- Recent Tasks -->
  <div class="card fade-up-3">
    <h3 style="margin-bottom:1rem">Recent Tasks</h3>
    <% if (recentTasks.length === 0) { %>
      <div class="empty">
        <div class="empty-icon">📌</div>
        <h3>No tasks yet</h3>
        <p>Your posted tasks will appear here.</p>
      </div>
    <% } else { %>
      <div class="table-wrap">
        <table>
          <thead>
            <tr>
              <th>Title</th>
              <th>Posted At</th>
            </tr>
          </thead>
          <tbody>
            <% recentTasks.forEach(task => { %>
              <tr>
                <td><strong><%= task.title %></strong></td>
                <td><%= new Date(task.posted_at).toLocaleString() %></td>
              </tr>
            <% }) %>
          </tbody>
        </table>
      </div>
    <% } %>
  </div>

  <div class="footer" style="margin-top:2rem;text-align:center;font-size:0.85rem;color:var(--gray-500)">
    Report generated on <%= generatedAt %> (Date range: <%= startDate %> to <%= endDate %>)
  </div>
</div>

<%- include('partials/footer') %>