<!DOCTYPE html>
<html>
  <head>
    <title>Business Summary Report</title>
    <style>
      body {
        font-family: Arial, sans-serif;
        background-color: #fff;
        color: #333;
        margin: 0;
        padding: 20px;
      }
      h2 {
        color: #1e3a8a;
        text-align: center;
        margin-bottom: 20px;
      }
      .actions {
        display: flex;
        justify-content: center;
        gap: 1rem;
        margin-bottom: 1rem;
      }
      .btn {
        padding: 0.4rem 0.8rem;
        border-radius: 4px;
        text-decoration: none;
        font-size: 0.9rem;
      }
      .btn-primary {
        background-color: #2563eb;
        color: #fff;
      }
      .btn-outline {
        border: 1px solid #2563eb;
        color: #2563eb;
      }
      .filter-form {
        max-width: 800px;
        margin: 0 auto 20px auto;
        display: flex;
        justify-content: center;
        gap: 15px;
        background: #f9fafb;
        padding: 15px;
        border-radius: 8px;
        border: 1px solid #e5e7eb;
      }
      .filter-form label {
        font-weight: 600;
        color: #1e40af;
      }
      .filter-form input {
        padding: 5px;
        border: 1px solid #cbd5e1;
        border-radius: 4px;
      }
      .report-container {
        max-width: 800px;
        margin: 0 auto;
        border: 1px solid #e5e7eb;
        border-radius: 8px;
        padding: 20px;
      }
      .report-item {
        display: flex;
        justify-content: space-between;
        padding: 8px 0;
        border-bottom: 1px solid #e5e7eb;
      }
      .report-item:last-child {
        border-bottom: none;
      }
      .label {
        font-weight: bold;
        color: #1e40af;
      }
      .value {
        font-weight: bold;
        color: #2563eb;
      }
      table {
        width: 100%;
        border-collapse: collapse;
        margin-top: 20px;
      }
      th, td {
        border: 1px solid #e5e7eb;
        padding: 8px;
        text-align: left;
      }
      th {
        background-color: #f3f4f6;
        color: #1e3a8a;
      }
      .footer {
        margin-top: 20px;
        text-align: center;
        font-size: 0.85rem;
        color: #666;
      }
    </style>
  </head>
  <body>
    <h2>Business Summary Report</h2>

    <!-- Action buttons -->
    <div class="actions">
      <a href="/business/dashboard" class="btn btn-outline">← Back to Dashboard</a>
      <a href="/business/reports/export-pdf?startDate=<%= startDate %>&endDate=<%= endDate %>" class="btn btn-primary">
        ⬇ Download PDF Report
      </a>
    </div>

    <!-- Filter Form -->
    <form method="get" action="/business/reports/summary" class="filter-form">
      <label for="startDate">Start Date:</label>
      <input type="date" id="startDate" name="startDate" value="<%= startDate || '' %>">

      <label for="endDate">End Date:</label>
      <input type="date" id="endDate" name="endDate" value="<%= endDate || '' %>">

      <button type="submit" class="btn btn-primary">Apply Filter</button>
    </form>

    <div class="report-container">
      <div class="report-item">
        <span class="label">Company:</span>
        <span class="value"><%= profile.company_name %></span>
      </div>
      <div class="report-item">
        <span class="label">Industry:</span>
        <span class="value"><%= profile.industry %></span>
      </div>
      <div class="report-item">
        <span class="label">Email:</span>
        <span class="value"><%= profile.company_email %></span>
      </div>
      <div class="report-item">
        <span class="label">Total Tasks Posted:</span>
        <span class="value"><%= tasksCount.total_tasks %></span>
      </div>
      <div class="report-item">
        <span class="label">Total Applicants:</span>
        <span class="value"><%= applicantsCount.total_applicants %></span>
      </div>
      <div class="report-item">
        <span class="label">Total Submissions:</span>
        <span class="value"><%= submissionsCount.total_submissions %></span>
      </div>
    </div>

    <h3>Recent Tasks</h3>
    <table>
      <thead>
        <tr>
          <th>Title</th>
          <th>Posted At</th>
        </tr>
      </thead>
      <tbody>
        <% recentTasks.forEach(task => { %>
          <tr>
            <td><%= task.title %></td>
            <td><%= new Date(task.posted_at).toLocaleString() %></td>
          </tr>
        <% }) %>
      </tbody>
    </table>

    <div class="footer">
      Report generated on <%= generatedAt %> (Date range: <%= startDate %> to <%= endDate %>)
    </div>
  </body>
</html>