<%- include('partials/header', { user: user, title: 'Industry Summary Report' }) %>

<div class="page-hero">
  <div class="page-hero-inner" style="display:flex;align-items:center;justify-content:space-between;flex-wrap:wrap;gap:1rem">
    <div>
      <h1 style="font-size:1.6rem;margin-bottom:0.2rem">Industry Summary Report</h1>
      <p style="color:var(--gray-600)">Activity grouped by industry, showing business and task counts.</p>
    </div>
    <a href="/admin/dashboard" class="btn btn-outline btn-sm">← Back to Dashboard</a>
  </div>
</div>

<div class="page">
  <!-- Filter Form -->
  <div class="card fade-up" style="margin-bottom:2rem">
    <form method="get" action="/admin/reports/industry-summary" style="display:flex;gap:1rem;flex-wrap:wrap;align-items:flex-end">
      <div>
        <label class="form-label" for="startDate">Start Date</label>
        <input type="date" id="startDate" name="startDate" value="<%= startDate || '' %>" class="form-input" style="width:auto">
      </div>
      <div>
        <label class="form-label" for="endDate">End Date</label>
        <input type="date" id="endDate" name="endDate" value="<%= endDate || '' %>" class="form-input" style="width:auto">
      </div>
      <button type="submit" class="btn btn-primary">Apply Filter</button>
    </form>
    <p style="font-size:0.875rem;color:var(--gray-600);margin-top:0.5rem">
      <% if (startDate && endDate) { %>
        Showing data from <%= startDate %> to <%= endDate %>
      <% } else { %>
        Showing all time data
      <% } %>
    </p>
  </div>

  <!-- Table -->
  <div class="card fade-up-2">
    <% if (data.length === 0) { %>
      <div class="empty">
        <div class="empty-icon">📊</div>
        <h3>No data available</h3>
        <p>No industry activity found for the selected period.</p>
      </div>
    <% } else { %>
      <div class="table-wrap">
        <table>
          <thead>
            <tr>
              <th>Industry</th>
              <th>Total Businesses</th>
              <th>Total Tasks</th>
            </tr>
          </thead>
          <tbody>
            <% data.forEach(row => { %>
              <tr>
                <td><strong><%= row.industry %></strong></td>
                <td><%= row.total_businesses %></td>
                <td><%= row.total_tasks %></td>
              </tr>
            <% }) %>
          </tbody>
        </table>
      </div>
    <% } %>
  </div>
</div>

<%- include('partials/footer') %>