<%- include('partials/header', { user: user, title: 'Combined Summary Report' }) %>

<div class="page-hero">
  <div class="page-hero-inner" style="display:flex;align-items:center;justify-content:space-between;flex-wrap:wrap;gap:1rem">
    <div>
      <h1 style="font-size:1.6rem;margin-bottom:0.2rem">CampusLancer Summary Reports</h1>
      <p style="color:var(--gray-600)">Comprehensive overview of platform activity across all categories.</p>
    </div>
    <a href="/admin/dashboard" class="btn btn-outline btn-sm">← Back to Dashboard</a>
  </div>
</div>

<div class="page">
  <!-- Management Summary -->
  <div class="card fade-up" style="margin-bottom:2rem">
    <h3 style="margin-bottom:1rem">Management Summary</h3>
    <div class="grid-3">
      <div class="stat-card">
        <div class="stat-label">Total Businesses</div>
        <div class="stat-value"><%= management.total_businesses %></div>
        <div class="stat-sub">Registered</div>
      </div>
      <div class="stat-card">
        <div class="stat-label">Total Students</div>
        <div class="stat-value"><%= management.total_students %></div>
        <div class="stat-sub">Registered</div>
      </div>
      <div class="stat-card">
        <div class="stat-label">Total Tasks</div>
        <div class="stat-value"><%= management.total_tasks %></div>
        <div class="stat-sub">Posted</div>
      </div>
      <div class="stat-card">
        <div class="stat-label">Total Applications</div>
        <div class="stat-value"><%= management.total_applications %></div>
        <div class="stat-sub">Submitted</div>
      </div>
      <div class="stat-card">
        <div class="stat-label">Accepted Applications</div>
        <div class="stat-value"><%= management.accepted_applications %></div>
        <div class="stat-sub">Approved</div>
      </div>
      <div class="stat-card">
        <div class="stat-label">Rejected Applications</div>
        <div class="stat-value"><%= management.rejected_applications %></div>
        <div class="stat-sub">Declined</div>
      </div>
      <div class="stat-card">
        <div class="stat-label">Total Submissions</div>
        <div class="stat-value"><%= management.total_submissions %></div>
        <div class="stat-sub">Completed</div>
      </div>
    </div>
  </div>

  <!-- Student Summary -->
  <div class="card fade-up-2" style="margin-bottom:2rem">
    <h3 style="margin-bottom:1rem">Student Summary</h3>
    <div class="grid-3">
      <div class="stat-card">
        <div class="stat-label">Total Students</div>
        <div class="stat-value"><%= student.total_students %></div>
        <div class="stat-sub">Registered</div>
      </div>
      <div class="stat-card">
        <div class="stat-label">Total Applications</div>
        <div class="stat-value"><%= student.total_applications %></div>
        <div class="stat-sub">Submitted</div>
      </div>
      <div class="stat-card">
        <div class="stat-label">Accepted Applications</div>
        <div class="stat-value"><%= student.accepted_applications %></div>
        <div class="stat-sub">Approved</div>
      </div>
      <div class="stat-card">
        <div class="stat-label">Rejected Applications</div>
        <div class="stat-value"><%= student.rejected_applications %></div>
        <div class="stat-sub">Declined</div>
      </div>
      <div class="stat-card">
        <div class="stat-label">Total Submissions</div>
        <div class="stat-value"><%= student.total_submissions %></div>
        <div class="stat-sub">Completed</div>
      </div>
    </div>
  </div>

  <!-- Task Status Summary -->
  <div class="card fade-up-3" style="margin-bottom:2rem">
    <h3 style="margin-bottom:1rem">Task Status Summary</h3>
    <div class="grid-3">
      <div class="stat-card">
        <div class="stat-label">Open Tasks</div>
        <div class="stat-value"><%= tasks.open %></div>
        <div class="stat-sub">Accepting applications</div>
      </div>
      <div class="stat-card">
        <div class="stat-label">In Progress Tasks</div>
        <div class="stat-value"><%= tasks.in_progress %></div>
        <div class="stat-sub">Active</div>
      </div>
      <div class="stat-card">
        <div class="stat-label">Closed Tasks</div>
        <div class="stat-value"><%= tasks.closed %></div>
        <div class="stat-sub">Completed</div>
      </div>
    </div>
  </div>

  <!-- Industry Summary -->
  <div class="card fade-up-4">
    <h3 style="margin-bottom:1rem">Industry Summary</h3>
    <% if (industry.length === 0) { %>
      <div class="empty">
        <div class="empty-icon">🏭</div>
        <h3>No industry data</h3>
        <p>No industry activity found.</p>
      </div>
    <% } else { %>
      <div class="table-wrap">
        <table>
          <thead>
            <tr>
              <th>Industry</th>
              <th>Total Businesses</th>
              <th>Total Tasks</th>
            </tr>
          </thead>
          <tbody>
            <% industry.forEach(row => { %>
              <tr>
                <td><strong><%= row.industry %></strong></td>
                <td><%= row.total_businesses %></td>
                <td><%= row.total_tasks %></td>
              </tr>
            <% }) %>
          </tbody>
        </table>
      </div>
    <% } %>
  </div>

  <!-- Footer -->
  <div style="margin-top:2rem;text-align:center;font-size:0.85rem;color:var(--gray-500)">
    CampusLancer Report — Generated on <%= new Date().toLocaleDateString() %>
    (Date range: <%= startDate %> to <%= endDate %>)
  </div>
</div>

<%- include('partials/footer') %>
