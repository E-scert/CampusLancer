<%- include('partials/header', { user: user, title: 'Management Summary Report' }) %>

<div class="page-hero">
  <div class="page-hero-inner" style="display:flex;align-items:center;justify-content:space-between;flex-wrap:wrap;gap:1rem">
    <div>
      <h1 style="font-size:1.6rem;margin-bottom:0.2rem">Management Summary Report</h1>
      <p style="color:var(--gray-600)">System-wide totals of businesses, students, tasks, applications, and submissions.</p>
    </div>
    <a href="/admin/dashboard" class="btn btn-outline btn-sm">← Back to Dashboard</a>
  </div>
</div>

<div class="page">
  <!-- Filter Form -->
  <div class="card fade-up" style="margin-bottom:2rem">
    <form method="get" action="/admin/reports/management-summary" style="display:flex;gap:1rem;flex-wrap:wrap;align-items:flex-end">
      <div>
        <label class="form-label" for="startDate">Start Date</label>
        <input type="date" id="startDate" name="startDate" value="<%= startDate || '' %>" class="form-input" style="width:auto">
      </div>
      <div>
        <label class="form-label" for="endDate">End Date</label>
        <input type="date" id="endDate" name="endDate" value="<%= endDate || '' %>" class="form-input" style="width:auto">
      </div>
      <button type="submit" class="btn btn-primary">Apply Filter</button>
    </form>
    <p style="font-size:0.875rem;color:var(--gray-600);margin-top:0.5rem">
      <% if (startDate && endDate) { %>
        Showing data from <%= startDate %> to <%= endDate %>
      <% } else { %>
        Showing all time data
      <% } %>
    </p>
  </div>

  <!-- Stats -->
  <div class="grid-3 fade-up-2">
    <div class="stat-card">
      <div class="stat-label">Total Businesses</div>
      <div class="stat-value"><%= data.total_businesses %></div>
      <div class="stat-sub">Registered</div>
    </div>
    <div class="stat-card">
      <div class="stat-label">Total Students</div>
      <div class="stat-value"><%= data.total_students %></div>
      <div class="stat-sub">Registered</div>
    </div>
    <div class="stat-card">
      <div class="stat-label">Open Tasks</div>
      <div class="stat-value"><%= data.open_tasks %></div>
      <div class="stat-sub">Currently accepting</div>
    </div>
    <div class="stat-card">
      <div class="stat-label">In Progress Tasks</div>
      <div class="stat-value"><%= data.in_progress_tasks %></div>
      <div class="stat-sub">Active</div>
    </div>
    <div class="stat-card">
      <div class="stat-label">Closed Tasks</div>
      <div class="stat-value"><%= data.closed_tasks %></div>
      <div class="stat-sub">Completed</div>
    </div>
    <div class="stat-card">
      <div class="stat-label">Total Applications</div>
      <div class="stat-value"><%= data.total_applications %></div>
      <div class="stat-sub">Submitted</div>
    </div>
    <div class="stat-card">
      <div class="stat-label">Accepted Applications</div>
      <div class="stat-value"><%= data.accepted_applications %></div>
      <div class="stat-sub">Approved</div>
    </div>
    <div class="stat-card">
      <div class="stat-label">Rejected Applications</div>
      <div class="stat-value"><%= data.rejected_applications %></div>
      <div class="stat-sub">Declined</div>
    </div>
    <div class="stat-card">
      <div class="stat-label">Total Submissions</div>
      <div class="stat-value"><%= data.total_submissions %></div>
      <div class="stat-sub">Completed</div>
    </div>
  </div>
</div>

<%- include('partials/footer') %>
