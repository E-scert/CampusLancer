<!DOCTYPE html>
<html>
  <head>
    <title>Management Summary Report</title>
    <style>
      body {
        font-family: Arial, sans-serif;
        background-color: #f0f4f8; /* light blue background */
        color: #333;
        margin: 0;
        padding: 20px;
      }

      h2 {
        color: #1e3a8a; /* deep blue */
        text-align: center;
        margin-bottom: 30px;
      }

      .report-container {
        max-width: 700px;
        margin: 0 auto;
        background-color: #ffffff; /* white card */
        border-radius: 10px;
        box-shadow: 0 4px 8px rgba(0, 0, 0, 0.1);
        padding: 25px;
      }

      .report-item {
        display: flex;
        justify-content: space-between;
        padding: 12px 0;
        border-bottom: 1px solid #e5e7eb;
      }

      .report-item:last-child {
        border-bottom: none;
      }

      .label {
        font-weight: bold;
        color: #1e40af; /* medium blue */
      }

      .value {
        font-weight: bold;
        color: #2563eb; /* bright blue */
      }

      .back-link {
        display: inline-block;
        margin: 1rem auto;
        text-decoration: none;
        color: #2563eb;
        font-weight: 600;
      }
    </style>
  </head>
  <%- include('partials/adminNav') %>
  <body>
    <h2>Management Summary Report</h2>

    <a href="/admin/dashboard" class="back-link">← Back to Dashboard</a>

    <div class="report-container">
      <div class="report-item">
        <span class="label">Total Businesses:</span>
        <span class="value"><%= data.total_businesses %></span>
      </div>
      <div class="report-item">
        <span class="label">Total Students:</span>
        <span class="value"><%= data.total_students %></span>
      </div>
      <div class="report-item">
        <span class="label">Open Tasks:</span>
        <span class="value"><%= data.open_tasks %></span>
      </div>
      <div class="report-item">
        <span class="label">In Progress Tasks:</span>
        <span class="value"><%= data.in_progress_tasks %></span>
      </div>
      <div class="report-item">
        <span class="label">Closed Tasks:</span>
        <span class="value"><%= data.closed_tasks %></span>
      </div>
      <div class="report-item">
        <span class="label">Total Applications:</span>
        <span class="value"><%= data.total_applications %></span>
      </div>
      <div class="report-item">
        <span class="label">Total Submissions:</span>
        <span class="value"><%= data.total_submissions %></span>
      </div>
    </div>
  </body>
</html>
